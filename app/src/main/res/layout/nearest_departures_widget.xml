<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nearest_departures_widget_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:theme="@style/Theme.NearestDepartures.AppWidgetContainer">

    <TextView
        android:id="@+id/nearest_departures_widget_station_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:contentDescription="@string/appwidget_text"
        android:text="no departures available"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <TextView
        android:id="@+id/nearest_departures_widget_departures_board"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TextView" />
</LinearLayout>